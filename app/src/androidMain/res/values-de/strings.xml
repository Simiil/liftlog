<?xml version="1.0" encoding="utf-8"?>
<!-- German counterpart of the Android-platform-facing strings; see values/strings.xml. -->
<resources>
    <string name="app_name">LiftLog</string>
    <string name="session_untitled">Schnelles Training</string>
    <string name="session_log_set">SATZ LOGGEN</string>
    <string name="session_notification_channel_name">Aktives Training</string>
    <string name="session_notification_channel_description">Zeigt das laufende Training mit schnellem Satz-Logging.</string>
    <string name="session_notification_placeholder">Training läuft</string>
    <!-- %1$d = nächste Satznummer, %2$d = Zielsätze, %3$s = nächstes Gewicht inkl. Einheit (z. B. 80 kg), %4$d = nächste Wdh. -->
    <string name="session_notification_body_target">Satz %1$d von %2$d · als Nächstes: %3$s × %4$d</string>
    <!-- %1$d = geloggte Sätze, %2$s = nächstes Gewicht inkl. Einheit, %3$d = nächste Wdh. -->
    <plurals name="session_notification_body_count">
        <item quantity="one">%1$d Satz · als Nächstes: %2$s × %3$d</item>
        <item quantity="other">%1$d Sätze · als Nächstes: %2$s × %3$d</item>
    </plurals>
    <string name="session_notification_body_empty">Noch keine Sätze · zum Loggen tippen</string>
</resources>
