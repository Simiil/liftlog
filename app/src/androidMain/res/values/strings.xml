<?xml version="1.0" encoding="utf-8"?>
<!--
    Android-platform-facing strings only. The full UI catalogue moved to CMP resources
    (src/commonMain/composeResources/values*/strings.xml) in PR5. These stay in Android
    res because they are consumed outside Compose, where CMP's suspend getString() cannot
    reach: app_name is referenced by the manifest (android:label), and the session
    notification is built synchronously in a foreground Service (startForeground must run
    inside onStartCommand — no coroutine). Both locales are present so lint's
    MissingTranslation still guards them. app_name/session_untitled/session_log_set are
    ALSO in CMP (used by the in-app UI); the value is identical in both places.
-->
<resources>
    <string name="app_name">LiftLog</string>
    <string name="session_untitled">Quick workout</string>
    <string name="session_log_set">LOG SET</string>
    <string name="session_notification_channel_name">Active workout</string>
    <string name="session_notification_channel_description">Shows the running workout with quick set logging.</string>
    <string name="session_notification_placeholder">Workout in progress</string>
    <!-- %1$d = next set number, %2$d = target sets, %3$s = next weight incl. unit (e.g. 80 kg), %4$d = next reps -->
    <string name="session_notification_body_target">Set %1$d of %2$d · next: %3$s × %4$d</string>
    <!-- %1$d = sets done, %2$s = next weight incl. unit (e.g. 80 kg), %3$d = next reps -->
    <plurals name="session_notification_body_count">
        <item quantity="one">%1$d set · next: %2$s × %3$d</item>
        <item quantity="other">%1$d sets · next: %2$s × %3$d</item>
    </plurals>
    <string name="session_notification_body_empty">No sets yet · tap to log</string>
</resources>
